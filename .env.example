# ChargebackKit env example
# Copy to .env.local for development; configure same vars in Render for production.

# --- Public site config ---
NEXT_PUBLIC_SITE_URL=https://chargebackkit.app
NEXT_PUBLIC_APP_URL=https://chargebackkit.app

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# --- Resend (transactional email) ---
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=ChargebackKit <noreply@chargebackkit.app>

# --- Optional: feature flags / observability ---
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
